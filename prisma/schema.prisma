generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth Models ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Models ────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  name        String
  status      String   // 'active' | 'planned' | 'paused'
  phase       String?  // 'idea' | 'research' | 'build' | 'testing' | 'live' | 'optimizing'
  category    String   // 'directory' | 'leadgen' | 'tool' | 'client' | 'business' | 'event'
  description String?
  revenue     Float?   // monthly estimate
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // New fields
  scratchPad    String?    // rich text scratch pad content
  businessUnit  String?    // 'agency' | 'rankrent' | 'affiliate' | 'tools' | 'leadgen' | 'festival'
  ownerType     String     @default("own")  // 'client' | 'own'
  clientName    String?
  clientEmail   String?
  contractType    String?    // 'retainer' | 'eenmalig' | 'mixed'
  monthlyFee      Float?
  contractStart   DateTime?
  contractEnd     DateTime?
  hoursPerMonth   Int?
  autoRenew       Boolean    @default(false)
  paymentStatus   String?    // 'current' | 'late' | 'overdue'
  lastInvoiceDate DateTime?
  nextInvoiceDate DateTime?

  // Relations
  sites      Site[]
  tasks      Task[]
  nowItems   NowItem[]
  content    Content[]
  research   Research[]
  activities Activity[]

  @@map("projects")
}

model Site {
  id        String   @id @default(cuid())
  domain    String
  projectId String?
  status    String   // 'planned' | 'dev' | 'staging' | 'live' | 'paused' | 'archived'
  category  String?  // 'klant' | 'leadgen' | 'adsense' | 'affiliate' | 'rank-rent' | 'tool' | 'directory' | 'business' | 'event'
  techStack String[] // Array of tech stack items
  revenue   Float?   // monthly estimate
  listings  Int?     // for directories
  pages     Int?     // for content sites
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // New fields
  lastContentDate   DateTime?
  monthlyRevenue    Float?
  revenueType       String?    // 'recurring' | 'one_time' | 'affiliate' | 'adsense' | 'leadgen' | 'rank_rent'
  lastRevenueUpdate DateTime?  // when revenue was last verified/updated
  seoStatus         String?    // 'growing' | 'stable' | 'declining' | 'unknown'
  nextAction        String?
  hosting           String?    // 'vercel' | 'cloudflare' | 'hostinger' | 'vps' | 'other'

  // FORGE: deployment & build tracking
  deployUrl         String?    // Vercel preview URL
  productionUrl     String?    // Live URL (e.g. https://datumberekenen.be)
  lastDeployAt      DateTime?  // Last successful deploy
  deployStatus      String?    // 'success' | 'failed' | 'building'
  vercelProjectId   String?    // Vercel project ID for API integration
  githubRepo        String?    // e.g. "Hazier007/spaarinteresten-be"
  defaultBranch     String?    @default("main")
  lastCommitAt      DateTime?
  buildStatus       String?    // 'passing' | 'failing' | 'unknown'
  lastBuildAt       DateTime?
  lighthouse        String?    // JSON: { performance: 95, seo: 100, accessibility: 92 }
  devPhase          String?    // 'design' | 'build' | 'testing' | 'deploy'

  // RADAR: SEO & domain fields
  seoScore          Int?       // 0-100 overall SEO health
  lastSeoAudit      DateTime?  // when last scanned by RADAR
  topKeyword        String?    // primary ranking keyword
  topPosition       Float?     // position on top keyword
  monthlyTraffic    Int?       // estimated sessions/month
  indexedPages       Int?       // pages in Google index
  domainAuthority   Int?       // DR/DA score
  expirationDate    DateTime?  // domain expiry date (critical for monitoring)
  registrar         String?    // DNS.be, Combell, etc.

  ownerType         String     @default("own")  // 'client' | 'own'
  clientName        String?
  clientEmail       String?
  contractType      String?    // 'retainer' | 'eenmalig' | 'mixed'
  monthlyFee        Float?
  contractStart     DateTime?
  contractEnd       DateTime?
  hoursPerMonth     Int?

  // Relations
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tasks   Task[]

  @@map("sites")
}

model Idea {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   // 'directory' | 'leadgen' | 'tool' | 'client' | 'business' | 'feature' | 'domain_acquisition' | 'new_project' | 'growth_strategy'
  priority    String   // 'low' | 'medium' | 'high'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Status & assignment
  status          String   @default("raw")  // 'raw' | 'evaluating' | 'promising' | 'active' | 'archived'
  businessUnit    String?
  revenueEstimate Float?
  assignedTo      String?  // agent name

  // SPARK scoring
  scoreOverall          Float?   // weighted total score (1-10)
  scoreFeasibility      Float?   // haalbaarheid (1-10)
  scoreRevenuePotential Float?   // inkomstenpotentieel (1-10)
  scoreTimeToRevenue    Float?   // snelheid naar geld (1-10)
  scoreCompetition      Float?   // concurrentieniveau (1-10, higher = less competition)
  scoreStrategicFit     Float?   // fit met portfolio (1-10)
  recommendation        String?  // 'build' | 'investigate' | 'skip'
  estimatedInvestment   String?  // e.g. "€50-200 + 40u"
  estimatedRevenue      String?  // e.g. "€200-500/maand na 6m"
  evaluatedAt           DateTime?
  evaluatedBy           String?  // 'spark'
  linkedProjectId       String?  // link to existing project

  // Lifecycle tracking
  convertedToTaskId     String?  // which task was created from this idea
  rejectedReason        String?  // why recommendation='skip'

  @@map("ideas")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    // 'todo' | 'in-progress' | 'done'
  projectId   String?
  siteId      String?
  priority    String?   // 'low' | 'medium' | 'high'
  assignee    String?   // 'bart' | 'atlas' | 'forge' | 'radar' | 'ink' | 'ledger' | 'spark' | 'cowork'
  dueDate     DateTime?
  notified    Boolean?
  notifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // New fields
  needsApproval   Boolean  @default(false)
  approvalSource  String?  // which agent requested approval
  source          String?  // 'manual' | 'agent' | 'cron'
  agentAssignee   String?  // 'atlas' | 'forge' | 'radar' | 'ink' | 'ledger' | 'spark'

  // Origin tracking
  linkedIdeaId    String?  // which idea led to this task
  linkedSprintId  String?  // which sprint this task belongs to
  linkedDomainId  String?  // task for a domain
  completedAt     DateTime? // when task was completed (for velocity tracking)
  category        String?  // 'seo' | 'dev' | 'content' | 'research' | 'general'

  // Subtasks
  parentTaskId    String?
  parentTask      Task?    @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks        Task[]   @relation("Subtasks")

  // Relations
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  site     Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  content  Content[]

  @@map("tasks")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  tags      String[] // Array of tags
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Agent context
  agentId       String?  // 'forge' | 'radar' | 'atlas' | etc.
  noteType      String?  // 'progress' | 'decision' | 'blocker' | 'review' | 'general' | 'feedback' | 'analysis' | 'lesson-learned'
  linkedTaskId  String?
  linkedSiteId  String?

  // Extended linking (feedback/analysis can attach to any core entity)
  linkedProjectId  String?
  linkedIdeaId     String?
  linkedContentId  String?
  linkedSprintId   String?
  linkedDomainId   String?

  // Feedback-specific fields
  sentiment     String?   // 'positive' | 'negative' | 'neutral' | 'mixed'
  actionNeeded  Boolean   @default(false)

  @@map("notes")
}

model NowItem {
  id          String   @id @default(cuid())
  title       String
  meta        String
  tag         String
  description String?
  projectId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("now_items")
}

model Alert {
  id           String    @id @default(cuid())
  title        String
  body         String
  priority     String    // 'low' | 'medium' | 'high'
  resolved     Boolean   @default(false)
  snoozedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("alerts")
}

model Cost {
  id           String    @id @default(cuid())
  name         String
  amount       Float     // amount in EUR
  category     String    // AI, Hosting, Database, Domains, Infrastructure, Tools, Other
  recurring    Boolean   // monthly recurring or one-time
  billingCycle String?   // 'monthly' | 'yearly' | 'one_time'
  notes        String?
  projectId    String?   // link cost to specific project (null = overhead)
  billingDate  DateTime? // date of one-time cost
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // New fields
  billingDay Int?    // day of month when billed

  @@map("costs")
}

model Content {
  id         String   @id @default(cuid())
  title      String
  body       String   // the actual content (markdown)
  type       String   // 'meta' | 'blogpost' | 'landingpage' | 'review' | 'faq' | 'social' | 'article' | 'product-review' | 'buyers-guide' | 'page' | 'other'
  status     String   // 'draft' | 'review' | 'approved' | 'rejected' | 'live'
  author     String   // 'bart' | 'atlas' | 'forge' | 'radar' | 'ink' | 'ledger' | 'spark' | 'cowork'
  targetSite String?  // e.g. 'preppedia.com', 'btw-calculator.be'
  targetPath String?  // e.g. '/guide/best-water-filters'
  projectId  String?
  feedback   String?  // Bart's review notes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Approval
  needsApproval   Boolean  @default(true)
  approvalSource  String?  // which agent requested approval

  // INK fields
  linkedKeyword   String?  // primary target keyword
  linkedTaskId    String?  // task that triggered this content
  wordCount       Int?     // auto-calculated on save

  // INK structured content extensions
  linkedSiteId    String?  // proper FK to Site
  linkedDomainId  String?  // FK to domain
  linkedContentId String?  // self-ref for content-updates (which content does this replace?)
  metadata        Json?    // structured data: seoMeta, contentBlocks, variants, brief, performance
  language        String?  // 'nl' | 'en' | 'fr' | 'de'
  handoffStatus   String?  // 'not-ready' | 'ready-for-review' | 'ready-for-publishing' | 'handed-off' | 'published'
  version         Int      @default(1) // version tracking
  parentId        String?  // previous version (for versioning chain)
  summary         String?  // short summary / excerpt

  // Relations
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task    Task?    @relation(fields: [linkedTaskId], references: [id], onDelete: SetNull)

  @@map("content")
}

model Research {
  id        String   @id @default(cuid())
  title     String
  body      String   // full markdown content
  type      String   // keyword-research | market-analysis | visibility-audit | domain-analysis | market-research | acquisition-memo | growth-evaluation | ...
  author    String   // 'bart' | 'atlas' | 'forge' | 'radar' | 'ink' | 'ledger' | 'spark' | 'cowork'
  projectId String?  // deprecated — use linkedSiteId/linkedDomainId
  tags      String?  // comma-separated
  status    String   // 'draft' | 'final' | 'outdated'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Website/Domain/Entity linking
  linkedSiteId    String?  // link to website
  linkedDomainId  String?  // link to domain
  linkedIdeaId    String?  // link to evaluated idea
  linkedTaskId    String?  // link to originating task

  // SPARK reporting extensions
  summary       String?           // Executive summary for list views (searchable)
  metadata      Json?             // Structured data: scores, findings, quickWins, risks, etc.
  needsApproval Boolean  @default(false) // Show in inbox/approval flow?
  reportDate    DateTime?         // When the analysis was conducted
  version       Int      @default(1)     // Report version tracking

  // Relations
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("research")
}

model Product {
  id              String   @id @default(cuid())
  name            String
  site            String
  category        String   @default("")
  affiliateUrl    String   @default("")
  imageUrl        String   @default("")
  price           String   @default("")
  status          String   @default("nieuw")
  keyword         String   @default("")
  searchVolume    String   @default("")
  competition     String   @default("")
  suggestedTitle  String   @default("")
  metaDescription String   @default("")
  seoNotes        String   @default("")
  description     String   @default("")
  pros            String   @default("")
  cons            String   @default("")
  specs           String   @default("")
  buyerGuide      String   @default("")
  assignedTo      String   @default("")
  notes           String   @default("")
  contentType     String   @default("product") // product, review, comparison, buyerguide, article, listicle
  compareItems    String   @default("") // JSON array of item names
  targetKeyword   String   @default("")
  wordCount       String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("products")
}

model Activity {
  id          String   @id @default(cuid())
  type        String   // 'commit' | 'deploy' | 'task' | 'content' | 'research' | 'alert' | 'system'
  actor       String   // 'bart' | 'atlas' | 'forge' | 'radar' | 'ink' | 'ledger' | 'spark' | 'cowork' | 'system'
  title       String
  description String?
  url         String?  // link to commit, deploy, etc
  projectId   String?
  metadata    String?  // JSON string for extra data
  createdAt   DateTime @default(now())

  // Relations
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("activities")
}

// ─── Agent Reports ─────────────────────────────────────────────────

model AgentReport {
  id          String   @id @default(cuid())
  agent       String   // 'forge' | 'atlas' | 'radar' | 'ink' | 'ledger' | 'spark'
  reportType  String   // FORGE: implementation-update | build-report | deploy-report | ... ATLAS: daily-brief | sprint-review | ... LEDGER: finance_snapshot | forecast_report | ...
  title       String
  summary     String?  // kort voor lijstweergave
  body        String?  // volledige tekst (markdown fallback)
  status      String   @default("done")    // draft | in-progress | blocked | done | shipped | failed | published | archived
  outcome     String?  // success | partial | blocked | failed | review-needed
  priority    String   @default("medium")  // low | medium | high | critical
  category    String   @default("dev")     // dev | seo | content | research | general | financial | strategy

  // Approval
  needsApproval   Boolean  @default(false)
  approvalReason  String?

  // Linking (polymorf, nullable)
  linkedTaskId      String?
  linkedSiteId      String?
  linkedSprintId    String?
  linkedContentId   String?
  linkedIdeaId      String?
  linkedDomainId    String?
  parentReportId    String?  // chained reports / follow-ups

  // Execution context — FORGE
  environment   String?  // local | preview | staging | production
  repo          String?  // bv. Hazier007/datumberekenen
  branch        String?  // git branch

  // Period context — LEDGER + ATLAS
  periodType    String?  // weekly | monthly | quarterly | ad_hoc | daily
  periodLabel   String?  // bv. 2026-04, 2026-W14, 2026-04-05
  currency      String?  // EUR | USD

  // Structured data (all agents pack their structured fields here)
  metadata      Json?

  // Timestamps
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("agent_reports")
}

// ─── SEO Reports (RADAR) ──────────────────────────────────────────

model SeoReport {
  id        String   @id @default(cuid())
  subtype   String   // site_audit | keyword_snapshot | traffic_analysis | domain_evaluation | opportunity_scan | signal
  agent     String   @default("radar")
  title     String
  summary   String?
  status    String   @default("final")  // draft | final | archived

  // Approval
  needsApproval  Boolean  @default(false)

  // Linking
  linkedSiteId    String?
  linkedDomainId  String?
  linkedTaskId    String?
  linkedContentId String?
  linkedIdeaId    String?
  runId           String?  // batch tracing: alle rapporten van één cron-run

  // SEO Metrics (top-level voor filtering/sortering)
  seoScore           Int?     // 0-100
  topKeyword         String?
  topPosition        Float?
  monthlyClicks      Int?
  monthlyImpressions Int?
  avgCtr             Float?
  quickWinCount      Int?
  dataSource         String?  // gsc | bing | dataforseo | manual | combined
  periodDays         Int?     // 28, 7, etc.

  // Structured data (keywords, recommendations, signals, metrics, rawData)
  metadata    Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("seo_reports")
}

// ─── New Agent & Revenue Models ─────────────────────────────────────

model AgentLog {
  id        String   @id @default(cuid())
  source    String   // agent name: atlas, forge, radar, ink, ledger, spark, cowork
  action    String   // task, idea, alert, note, context
  payload   String   // JSON string
  createdAt DateTime @default(now())

  @@map("agent_logs")
}

model RevenueEntry {
  id           String   @id @default(cuid())
  source       String   // 'adsense' | 'agency' | 'affiliate' | 'domain' | 'leadgen'
  description  String
  amount       Float
  month        String   // '2026-01' format
  projectId    String?
  siteDomain   String?
  recurring    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("revenue_entries")
}

model DomainOpportunity {
  id             String   @id @default(cuid())
  domain         String
  status         String   // 'parking' | 'developing' | 'forsale' | 'expired-watching' | 'acquired' | 'prospect'
  estimatedValue Float?
  niche          String?
  priority       String?  // 'low' | 'medium' | 'high'
  notes          String?
  radarNotes     String?  // notes from RADAR agent
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Extended fields for Domeinen hub
  linkedIdeaId   String?  // SPARK can link an idea evaluation
  businessUnit   String?  // 'hazier' | 'agency' | 'rankrent' | 'affiliate' | 'tools' | 'leadgen'
  hasIdea        Boolean  @default(false) // quick filter: has linked idea
  category       String?  // 'parking' | 'prospect' | 'acquired' | 'forsale'
  renewalDate    DateTime?
  provider       String?  // 'hazier' | 'transip' | 'combell' | 'godaddy' | 'cloudflare' | 'other'

  @@map("domain_opportunities")
}

model KPI {
  id         String   @id @default(cuid())
  name       String   // 'MRR' | 'Actieve sites' | 'Leads per maand' etc.
  value      Float
  unit       String   // '€' | '%' | 'aantal' | 'leads'
  target     Float?   // target value
  measuredAt DateTime @default(now())
  measuredBy String?  // 'ledger' | 'system' | 'bart'

  @@map("kpis")
}

model FinanceSnapshot {
  id              String   @id @default(cuid())
  period          String   // '2026-04' format
  totalMRR        Float    // total monthly recurring revenue
  totalCosts      Float    // total monthly costs
  netProfit       Float    // MRR - costs
  activeClients   Int      // number of paying clients
  liveSites       Int      // number of live sites with revenue
  domainCount     Int?     // total domains in portfolio
  notes           String?  // LEDGER's commentary
  createdBy       String   @default("ledger")
  createdAt       DateTime @default(now())

  @@unique([period])
  @@map("finance_snapshots")
}

model KeywordHistory {
  id          String   @id @default(cuid())
  siteId      String?
  domain      String   // site domain for easy querying
  keyword     String
  page        String?  // URL of ranking page
  position    Float
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  date        DateTime @default(now()) // measurement date
  source      String   @default("radar") // 'radar' | 'cron' | 'windsor'

  @@index([domain, keyword, date])
  @@index([domain, date])
  @@map("keyword_history")
}

model AgentMessage {
  id        String   @id @default(cuid())
  fromAgent String   // 'radar' | 'ink' | 'forge' | etc.
  toAgent   String   // 'radar' | 'ink' | 'forge' | 'bart' | etc.
  message   String
  taskId    String?  // optional linked task
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([toAgent, read])
  @@map("agent_messages")
}

model Sprint {
  id            String   @id @default(cuid())
  week          String   @unique // '2026-W14' format
  status        String   @default("active") // 'planning' | 'active' | 'completed' | 'cancelled'
  goals         String?  // JSON array of sprint goals
  summary       String?  // ATLAS end-of-week summary
  retrospective String?  // lessons learned after sprint completion
  createdBy     String   @default("atlas")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("sprints")
}

model Decision {
  id          String   @id @default(cuid())
  title       String                          // "Idea X: build of skip?"
  context     String                          // situation description, what was on the table
  outcome     String                          // 'approved' | 'rejected' | 'deferred' | 'adjusted'
  rationale   String                          // the WHY — core field
  decidedBy   String                          // 'bart' | agent name
  category    String   @default("general")    // 'idea-eval' | 'project-direction' | 'resource' | 'technical' | 'financial' | 'general'

  // Polymorphic linking (optional, at least 1 should be filled)
  projectId   String?
  ideaId      String?
  taskId      String?
  siteId      String?

  // Follow-up tracking
  resultStatus  String?   // 'pending' | 'implemented' | 'superseded' | 'reversed'
  reviewDate    DateTime? // when to reconsider
  tags          String[]  // free tags for filtering

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("decisions")
}

// ─── Crypto Bot Models ───────────────────────────────────────────────

model BotConfig {
  id             String   @id @default(cuid())
  coin           String   // BTC, ETH, SOL, etc.
  market         String   // BTC-EUR, ETH-EUR, etc.
  active         Boolean  @default(true)
  trailingPct    Float    @default(0.15)  // trailing stop %
  dcaSteps       Int      @default(4)     // hoeveel DCA herinkoop stappen
  dcaStepPct     Float    @default(0.05)  // % daling per DCA stap
  dcaStepWeight  Float    @default(0.25)  // fractie per DCA stap
  coreHoldPct    Float    @default(0.60)  // % core positie (nooit verkopen)
  tradePct       Float    @default(0.30)  // % trade positie
  cashPct        Float    @default(0.10)  // % cash reserve
  targetAlloc    Float?   // doel % van totaal portfolio
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  trades         BotTrade[]

  @@unique([coin])
  @@map("bot_configs")
}

model BotTrade {
  id          String   @id @default(cuid())
  configId    String
  config      BotConfig @relation(fields: [configId], references: [id])
  coin        String   // BTC, ETH, etc.
  market      String   // BTC-EUR
  side        String   // buy | sell
  type        String   // trailing_stop | dca_rebuy | manual | rebalance
  amount      Float    // hoeveelheid coin
  price       Float    // prijs per coin in EUR
  totalEur    Float    // totaal in EUR
  reason      String?  // "trailing stop hit at 12%", "DCA step 2/4 at -10%"
  orderId     String?  // Bitvavo order ID
  status      String   @default("filled") // pending | filled | failed | cancelled
  createdAt   DateTime @default(now())

  @@index([coin, createdAt])
  @@map("bot_trades")
}

model BotPosition {
  id            String   @id @default(cuid())
  coin          String   @unique
  market        String
  totalAmount   Float    @default(0)  // totaal coins in bezit
  avgBuyPrice   Float    @default(0)  // gemiddelde aankoopprijs
  highestPrice  Float    @default(0)  // hoogste prijs (voor trailing stop)
  currentPrice  Float    @default(0)  // laatste bekende prijs
  currentValue  Float    @default(0)  // huidige waarde in EUR
  pnlEur        Float    @default(0)  // P&L in EUR
  pnlPct        Float    @default(0)  // P&L in %
  status        String   @default("holding") // holding | trailing | sold | dca_rebuy
  dcaStep       Int      @default(0)  // huidige DCA herinkoop stap (0=geen)
  soldAt        Float?   // prijs waarop verkocht (na trailing stop)
  soldAmount    Float?   // hoeveel verkocht
  lastTickAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("bot_positions")
}

model BotSnapshot {
  id            String   @id @default(cuid())
  totalValue    Float    // totale portfolio waarde in EUR
  totalPnlEur   Float    // totale P&L in EUR
  totalPnlPct   Float    // totale P&L in %
  cashBalance   Float    @default(0)  // cash beschikbaar
  positions     Json     // snapshot van alle posities
  fearGreed     Int?     // Fear & Greed index op dat moment
  btcDominance  Float?   // BTC dominance %
  createdAt     DateTime @default(now())

  @@map("bot_snapshots")
}

model Lead {
  id           String    @id @default(cuid())
  name         String    // contact person name
  company      String?   // company name
  email        String?
  phone        String?
  website      String?
  source       String?   // 'website' | 'referral' | 'cold' | 'linkedin' | 'other'
  status       String    @default("nieuw") // 'nieuw' | 'contact' | 'proposal' | 'onderhandeling' | 'gewonnen' | 'verloren'
  notes        String?
  proposal     String?   // proposal/offerte details or link
  estimatedValue Float?  // estimated deal value
  service      String?   // what service they need: 'website' | 'seo' | 'both' | 'other'
  nextFollowUp DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("leads")
}
